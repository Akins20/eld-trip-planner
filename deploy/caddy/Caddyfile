# Domain, upstream, and DuckDNS token come from the environment at runtime, so
# nothing secret or host-specific is committed.
{
	# We use the DNS-01 challenge and a non-standard HTTPS port, so do not bind
	# port 80 for HTTP->HTTPS redirects (it is used by other services on the host).
	auto_https disable_redirects
}

{$SITE_ADDRESS} {
	tls {
		dns duckdns {env.DUCKDNS_TOKEN}
		resolvers 1.1.1.1
	}
	reverse_proxy {$UPSTREAM} {
		header_up X-Forwarded-Proto https
	}
}
